-- ============================================================
-- TABLE: txn_stock_movement_history
-- Purpose:
-- Stores stock movement history.
-- Examples:
-- Supplier to warehouse, warehouse to machine, machine consumption,
-- wastage, expiry adjustment, manual correction.
-- ============================================================

CREATE TABLE txn_stock_movement_history (
    id                          INT              NOT NULL AUTO_INCREMENT PRIMARY KEY COMMENT 'Primary Key - Unique ID for each stock movement transaction',

    movement_reference_no       VARCHAR(100)     NOT NULL COMMENT 'Unique stock movement reference number generated by application',
    movement_type               VARCHAR(50)      NOT NULL COMMENT 'Type of movement such as PURCHASE_IN, WAREHOUSE_TO_MACHINE, MACHINE_CONSUMPTION, WASTAGE, EXPIRY, MANUAL_ADJUSTMENT',

