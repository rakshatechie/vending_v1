USE beverage_vending_machine;


-- ============================================================
-- TABLE: master_user
-- Purpose: Stores users who operate, configure, maintain, or use
--          the beverage vending machine system.
-- ============================================================

CREATE TABLE master_user (
    id                  INT              NOT NULL AUTO_INCREMENT PRIMARY KEY COMMENT 'Primary Key - Unique ID for each user in the system',

    first_name          VARCHAR(100)     NOT NULL COMMENT 'User first name, for example Rahul, Priya, John',
    middle_name         VARCHAR(100)     NULL COMMENT 'User middle name, if applicable',
    last_name           VARCHAR(100)     NULL COMMENT 'User last name or surname',
    date_of_birth       DATE             NULL COMMENT 'Date of birth of the user, useful for customer profiling if required',
    email               VARCHAR(255)     NOT NULL COMMENT 'Unique email address of the user, used for login or communication',
    phone_number        VARCHAR(20)      NULL COMMENT 'Mobile or contact number of the user',
    address_line_1      VARCHAR(255)     NULL COMMENT 'Primary address line such as house number, street, building',
    address_line_2      VARCHAR(255)     NULL COMMENT 'Secondary address line such as landmark, area, apartment',
    city                VARCHAR(100)     NULL COMMENT 'City of residence or operation',
    state               VARCHAR(100)     NULL COMMENT 'State, province, or region',
    country             VARCHAR(100)     NULL COMMENT 'Country name',
    postal_code         VARCHAR(20)      NULL COMMENT 'Postal code or ZIP code',
    user_type           VARCHAR(50)      NOT NULL DEFAULT 'CUSTOMER' COMMENT 'Type of user such as ADMIN, CUSTOMER, OPERATOR, SERVICE_ENGINEER',
    preferred_language  VARCHAR(50)      NULL COMMENT 'Preferred user language for display or notification, for example English, Hindi',
    is_active           TINYINT          NOT NULL DEFAULT 1 COMMENT 'Indicates whether the user is active. Values may be expanded in future beyond 0 and 1',

    created_by_id       INT              NOT NULL COMMENT 'Audit Column - User ID who created this user record. Foreign Key to master_user(id)',
    created_on          DATETIME         NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT 'Audit Column - Date and time when this user record was created',
    updated_by_id       INT              NULL COMMENT 'Audit Column - User ID who last updated this user record. Foreign Key to master_user(id). Can be null for first insert',
    updated_on          DATETIME         NULL DEFAULT NULL ON UPDATE CURRENT_TIMESTAMP COMMENT 'Audit Column - Date and time when this user record was last updated. Can be null for first insert',

    UNIQUE KEY uk_master_user_email             (email),
    UNIQUE KEY uk_master_user_phone_number      (phone_number),
    KEY idx_master_user_name                    (first_name, last_name),
    KEY idx_master_user_created_by_id           (created_by_id),
    KEY idx_master_user_updated_by_id           (updated_by_id),

    CONSTRAINT fk_master_user_created_by
        FOREIGN KEY (created_by_id)
        REFERENCES master_user (id),

    CONSTRAINT fk_master_user_updated_by
        FOREIGN KEY (updated_by_id)
        REFERENCES master_user (id)

) ENGINE = InnoDB
  DEFAULT CHARSET = utf8mb4
  COLLATE = utf8mb4_unicode_ci
  COMMENT = 'Master table for application users such as customers, admins, operators, and service engineers';


