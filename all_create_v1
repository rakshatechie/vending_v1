-- ============================================================
-- TABLE: map_user_combo_ingredient
-- Purpose:
-- Stores ingredient-level details for each user beverage combination.
-- Example:
-- Combo 101 -> Milk 90 ML, Water 50 ML, Tea 6 GM, Sugar 3 GM.
-- ============================================================

CREATE TABLE map_user_combo_ingredient (
    id                          INT              NOT NULL AUTO_INCREMENT PRIMARY KEY COMMENT 'Primary Key - Unique ID for each user combination ingredient row',

    combo_id                    INT              NOT NULL COMMENT 'Foreign Key to master_user_beverage_combination(id). Identifies the user beverage combination',
