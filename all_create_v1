    KEY idx_master_beverage_display_order           (display_order),
    KEY idx_master_beverage_created_by_id           (created_by_id),
    KEY idx_master_beverage_updated_by_id           (updated_by_id),

    CONSTRAINT fk_master_beverage_created_by
        FOREIGN KEY (created_by_id)
        REFERENCES master_user (id),

