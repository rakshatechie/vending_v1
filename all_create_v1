    beverage_type                   VARCHAR(100)     NOT NULL COMMENT 'Category or type of beverage, for example HOT, COLD, MILK_BASED, WATER_BASED, FRUIT_BASED',
    beverage_description            VARCHAR(500)     NULL COMMENT 'Detailed description of the beverage, taste, usage, or serving information',
    beverage_default_quantity_ml    DECIMAL(10,2)    NOT NULL DEFAULT 150.00 COMMENT 'Default serving quantity of the beverage in milliliters',
    default_temperature_type        VARCHAR(50)      NULL COMMENT 'Default temperature type such as HOT, COLD, ROOM_TEMPERATURE',
    default_temperature_celsius     DECIMAL(6,2)     NULL COMMENT 'Default serving temperature in Celsius, if applicable',
