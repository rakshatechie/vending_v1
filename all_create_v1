    sequence_no                 INT              NOT NULL DEFAULT 0 COMMENT 'Sequence in which this ingredient should be added while preparing the user-specific beverage',
    is_active                   TINYINT          NOT NULL DEFAULT 1 COMMENT 'Indicates whether this ingredient row is active for the combination. Future values may go beyond 0 and 1',

    created_by_id               INT              NOT NULL COMMENT 'Audit Column - User ID who created this combination ingredient record. Foreign Key to master_user(id)',
    created_on                  DATETIME         NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT 'Audit Column - Date and time when this combination ingredient record was created',
    updated_by_id               INT              NULL COMMENT 'Audit Column - User ID who last updated this combination ingredient record. Foreign Key to master_user(id). Can be null for first insert',
    updated_on                  DATETIME         NULL DEFAULT NULL ON UPDATE CURRENT_TIMESTAMP COMMENT 'Audit Column - Date and time when this combination ingredient record was last updated. Can be null for first insert',

    UNIQUE KEY uk_user_combo_ing                 (combo_id, ingredient_id, ingredient_subtype_id_key),
    UNIQUE KEY uk_user_combo_ing_seq             (combo_id, sequence_no),

    KEY idx_user_combo_ing_combo_id              (combo_id),
    KEY idx_user_combo_ing_ingredient_id         (ingredient_id),
    KEY idx_user_combo_ing_subtype_id            (ingredient_subtype_id),
    KEY idx_user_combo_ing_created_by            (created_by_id),
    KEY idx_user_combo_ing_updated_by            (updated_by_id),

    CONSTRAINT fk_user_combo_ing_combo
        FOREIGN KEY (combo_id)
        REFERENCES master_user_beverage_combination (id),

    CONSTRAINT fk_user_combo_ing_ingredient
        FOREIGN KEY (ingredient_id)
        REFERENCES master_ingredient (id),

    CONSTRAINT fk_user_combo_ing_subtype
        FOREIGN KEY (ingredient_subtype_id)
        REFERENCES master_ingredient_subtype (id),

    CONSTRAINT fk_user_combo_ing_created_by
        FOREIGN KEY (created_by_id)
        REFERENCES master_user (id),

    CONSTRAINT fk_user_combo_ing_updated_by
        FOREIGN KEY (updated_by_id)
        REFERENCES master_user (id)

) ENGINE = InnoDB
  DEFAULT CHARSET = utf8mb4
  COLLATE = utf8mb4_unicode_ci
  COMMENT = 'Stores ingredient quantities and subtypes for each user-specific beverage combination';








-- ============================================================
-- TABLE: txn_beverage_serving
-- Purpose:
-- Stores every beverage served from a machine.
-- Supports:
-- 1. User serving for self.
-- 2. User serving for another registered user.
-- 3. User serving for a friend who is not registered.
-- ============================================================

CREATE TABLE txn_beverage_serving (
    id                              INT              NOT NULL AUTO_INCREMENT PRIMARY KEY COMMENT 'Primary Key - Unique ID for each beverage serving transaction',

    serving_reference_no            VARCHAR(100)     NOT NULL COMMENT 'Unique reference number generated by application for each beverage serving transaction',

    machine_id                      INT              NOT NULL COMMENT 'Foreign Key to master_vending_machine(id). Machine from which beverage was served',
    requested_by_user_id            INT              NOT NULL COMMENT 'Foreign Key to master_user(id). User who requested or paid for the beverage',
    served_for_user_id              INT              NULL COMMENT 'Foreign Key to master_user(id). Registered user for whom beverage was served, if different from requester',

    served_for_guest_name           VARCHAR(150)     NULL COMMENT 'Name of guest or friend if beverage is served for a non-registered person',
    served_for_guest_phone          VARCHAR(20)      NULL COMMENT 'Phone number of guest or friend if available',
    served_for_guest_email          VARCHAR(255)     NULL COMMENT 'Email of guest or friend if available',

    beverage_id                     INT              NOT NULL COMMENT 'Foreign Key to master_beverage(id). Beverage that was served',
    combo_id                        INT              NULL COMMENT 'Foreign Key to master_user_beverage_combination(id). User-specific combination used for serving, if applicable',

    serving_quantity_ml             DECIMAL(10,2)    NULL COMMENT 'Final beverage serving quantity in milliliters',
    serving_status                  VARCHAR(50)      NOT NULL DEFAULT 'REQUESTED' COMMENT 'Serving status such as REQUESTED, PREPARING, COMPLETED, FAILED, CANCELLED',
    served_on                       DATETIME         NULL COMMENT 'Date and time when beverage serving was completed',
    failure_reason                  VARCHAR(500)     NULL COMMENT 'Failure reason if beverage could not be served',
    remarks                         VARCHAR(500)     NULL COMMENT 'Additional notes about this beverage serving transaction',

    created_by_id                   INT              NOT NULL COMMENT 'Audit Column - User ID who created this serving record. Foreign Key to master_user(id)',
    created_on                      DATETIME         NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT 'Audit Column - Date and time when this serving record was created',
    updated_by_id                   INT              NULL COMMENT 'Audit Column - User ID who last updated this serving record. Foreign Key to master_user(id). Can be null for first insert',
    updated_on                      DATETIME         NULL DEFAULT NULL ON UPDATE CURRENT_TIMESTAMP COMMENT 'Audit Column - Date and time when this serving record was last updated. Can be null for first insert',

    UNIQUE KEY uk_serving_reference_no              (serving_reference_no),

    KEY idx_serving_machine_id                      (machine_id),
    KEY idx_serving_requested_by                    (requested_by_user_id),
    KEY idx_serving_for_user                        (served_for_user_id),
    KEY idx_serving_beverage_id                     (beverage_id),
    KEY idx_serving_combo_id                        (combo_id),
    KEY idx_serving_status                          (serving_status),
    KEY idx_serving_served_on                       (served_on),
    KEY idx_serving_created_by                      (created_by_id),
    KEY idx_serving_updated_by                      (updated_by_id),

    CONSTRAINT fk_serving_machine
        FOREIGN KEY (machine_id)
        REFERENCES master_vending_machine (id),

    CONSTRAINT fk_serving_requested_by
        FOREIGN KEY (requested_by_user_id)
        REFERENCES master_user (id),

    CONSTRAINT fk_serving_for_user
        FOREIGN KEY (served_for_user_id)
        REFERENCES master_user (id),

    CONSTRAINT fk_serving_beverage
        FOREIGN KEY (beverage_id)
        REFERENCES master_beverage (id),

    CONSTRAINT fk_serving_combo
        FOREIGN KEY (combo_id)
        REFERENCES master_user_beverage_combination (id),

    CONSTRAINT fk_serving_created_by
        FOREIGN KEY (created_by_id)
        REFERENCES master_user (id),

    CONSTRAINT fk_serving_updated_by
        FOREIGN KEY (updated_by_id)
        REFERENCES master_user (id)

) ENGINE = InnoDB
  DEFAULT CHARSET = utf8mb4
  COLLATE = utf8mb4_unicode_ci
  COMMENT = 'Transaction table storing every beverage served from vending machines, including self orders and orders for friends or guests';






-- ============================================================
-- TABLE: txn_beverage_serving_ingredient
-- Purpose:
-- Stores actual ingredient quantity consumed for each beverage serving.
-- This is important because user combinations may change in future,
-- but historical serving records should remain unchanged.
-- ============================================================

CREATE TABLE txn_beverage_serving_ingredient (
    id                          INT              NOT NULL AUTO_INCREMENT PRIMARY KEY COMMENT 'Primary Key - Unique ID for each served beverage ingredient detail row',

    serving_id                  INT              NOT NULL COMMENT 'Foreign Key to txn_beverage_serving(id). Identifies the beverage serving transaction',
    ingredient_id               INT              NOT NULL COMMENT 'Foreign Key to master_ingredient(id). Ingredient consumed during this serving',
    ingredient_subtype_id       INT              NULL COMMENT 'Foreign Key to master_ingredient_subtype(id). Optional subtype consumed during this serving',
    ingredient_subtype_id_key   INT              GENERATED ALWAYS AS (IFNULL(ingredient_subtype_id, 0)) STORED COMMENT 'Generated helper column used only for unique constraint because MySQL allows multiple NULL values in unique keys',

    consumed_quantity           DECIMAL(10,3)    NOT NULL DEFAULT 0.000 COMMENT 'Actual quantity of ingredient consumed for this beverage serving',
    unit_of_measurement         VARCHAR(30)      NOT NULL COMMENT 'Measurement unit of consumed quantity such as ML, GM, PIECE, SPOON',
    machine_stock_id            INT              NULL COMMENT 'Foreign Key to map_machine_ingredient_stock(id). Stock row from which this ingredient was consumed, if tracked',
    remarks                     VARCHAR(500)     NULL COMMENT 'Additional notes about this ingredient consumption',

    created_by_id               INT              NOT NULL COMMENT 'Audit Column - User ID who created this serving ingredient record. Foreign Key to master_user(id)',
    created_on                  DATETIME         NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT 'Audit Column - Date and time when this serving ingredient record was created',
    updated_by_id               INT              NULL COMMENT 'Audit Column - User ID who last updated this serving ingredient record. Foreign Key to master_user(id). Can be null for first insert',
    updated_on                  DATETIME         NULL DEFAULT NULL ON UPDATE CURRENT_TIMESTAMP COMMENT 'Audit Column - Date and time when this serving ingredient record was last updated. Can be null for first insert',

    UNIQUE KEY uk_serving_ing                    (serving_id, ingredient_id, ingredient_subtype_id_key),

    KEY idx_serving_ing_serving_id               (serving_id),
    KEY idx_serving_ing_ingredient_id            (ingredient_id),
    KEY idx_serving_ing_subtype_id               (ingredient_subtype_id),
    KEY idx_serving_ing_machine_stock            (machine_stock_id),
    KEY idx_serving_ing_created_by               (created_by_id),
    KEY idx_serving_ing_updated_by               (updated_by_id),

    CONSTRAINT fk_serving_ing_serving
        FOREIGN KEY (serving_id)
        REFERENCES txn_beverage_serving (id),

    CONSTRAINT fk_serving_ing_ingredient
        FOREIGN KEY (ingredient_id)
        REFERENCES master_ingredient (id),

    CONSTRAINT fk_serving_ing_subtype
        FOREIGN KEY (ingredient_subtype_id)
        REFERENCES master_ingredient_subtype (id),

    CONSTRAINT fk_serving_ing_machine_stock
        FOREIGN KEY (machine_stock_id)
        REFERENCES map_machine_ingredient_stock (id),

    CONSTRAINT fk_serving_ing_created_by
        FOREIGN KEY (created_by_id)
        REFERENCES master_user (id),

    CONSTRAINT fk_serving_ing_updated_by
        FOREIGN KEY (updated_by_id)
        REFERENCES master_user (id)

) ENGINE = InnoDB
  DEFAULT CHARSET = utf8mb4
  COLLATE = utf8mb4_unicode_ci
  COMMENT = 'Stores actual ingredient consumption snapshot for every beverage serving transaction';


