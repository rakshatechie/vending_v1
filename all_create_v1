        REFERENCES master_warehouse (id),

    CONSTRAINT fk_stock_move_dest_machine
        FOREIGN KEY (destination_machine_id)
        REFERENCES master_vending_machine (id),

    CONSTRAINT fk_stock_move_ingredient
        FOREIGN KEY (ingredient_id)
        REFERENCES master_ingredient (id),

