    is_active                       TINYINT          NOT NULL DEFAULT 1 COMMENT 'Indicates whether the beverage is active and available. Future values may go beyond 0 and 1',

    created_by_id                   INT              NOT NULL COMMENT 'Audit Column - User ID who created this beverage record. Foreign Key to master_user(id)',
    created_on                      DATETIME         NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT 'Audit Column - Date and time when this beverage record was created',
    updated_by_id                   INT              NULL COMMENT 'Audit Column - User ID who last updated this beverage record. Foreign Key to master_user(id). Can be null for first insert',
    updated_on                      DATETIME         NULL DEFAULT NULL ON UPDATE CURRENT_TIMESTAMP COMMENT 'Audit Column - Date and time when this beverage record was last updated. Can be null for first insert',

