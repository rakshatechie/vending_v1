    KEY idx_stock_move_ingredient                (ingredient_id),
    KEY idx_stock_move_subtype                   (ingredient_subtype_id),
    KEY idx_stock_move_created_by                (created_by_id),
    KEY idx_stock_move_updated_by                (updated_by_id),

    CONSTRAINT fk_stock_move_src_wh
